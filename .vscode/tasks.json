{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Build & Upload to Google Drive",
            "type": "shell",
            "command": "python",
            "args": [
                "tools/build_and_upload.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}