rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rides collection rules
    match /rides/{rideId} {
      // Allow read for all authenticated users
      allow read: if request.auth != null;
      
      // Allow create for authenticated users
      allow create: if request.auth != null
        && request.resource.data.creatorId == request.auth.uid;
      
      // Allow update: creator can update their own pending rides, 
      // OR driver can accept/cancel ongoing rides
      allow update: if request.auth != null && (
        // Creator can update their own pending rides
        (resource.data.creatorId == request.auth.uid && resource.data.status == 'pending')
        || 
        // Driver can accept (change from pending to ongoing)
        (request.resource.data.status == 'ongoing' && resource.data.status == 'pending')
        ||
        // Driver can cancel their accepted ride (change back to pending)
        (request.resource.data.status == 'pending' && resource.data.status == 'ongoing' && resource.data.driverId == request.auth.uid)
        ||
        // Anyone can mark as completed (auto-complete)
        (request.resource.data.status == 'completed' && resource.data.status == 'ongoing')
      );
      
      // Allow delete: only creator can delete their own pending rides
      allow delete: if request.auth != null 
        && resource.data.creatorId == request.auth.uid 
        && resource.data.status == 'pending';
    }
    
    // Users collection rules
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Never allow delete
    }
    
    // Scheduled routes collection rules
    match /scheduled_routes/{routeId} {
      // Allow read for all authenticated users
      allow read: if request.auth != null;
      
      // Allow create for authenticated users
      allow create: if request.auth != null
        && request.resource.data.creatorId == request.auth.uid;
      
      // Allow update: creator can update their own active routes
      allow update: if request.auth != null 
        && resource.data.creatorId == request.auth.uid;
      
      // Allow delete: only creator can delete (soft delete via status update)
      allow delete: if request.auth != null 
        && resource.data.creatorId == request.auth.uid;
    }
    
    // Ride cancellations log - only system can write, authenticated can read
    match /ride_cancellations/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.driverId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
